"""
Given a string s, return true if it is a palindrome, otherwise return false.

A palindrome is a string that reads the same forward and backward. It is also case-insensitive and ignores all non-alphanumeric characters.

Note: Alphanumeric characters consist of letters (A-Z, a-z) and numbers (0-9).

Example 1:

Input: s = "Was it a car or a cat I saw?"

Output: true
Explanation: After considering only alphanume

"""

class Solution:
    def isPalindrome(self, s: str) -> bool:
        left = 0
        right = len(s) - 1

        while left < right:
            # Skip non-letter and non-number characters from the left
            while left < right and not s[left].isalnum():
                left += 1

            # Skip non-letter and non-number characters from the right
            while left < right and not s[right].isalnum():
                right -= 1

            # Compare lowercase versions of both characters
            if s[left].lower() != s[right].lower():
                return False

            left += 1
            right -= 1

        return True
