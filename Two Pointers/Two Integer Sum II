"""
Given an array of integers numbers that is sorted in non-decreasing order.

Return the indices (1-indexed) of two numbers, [index1, index2], such that they add up to a given target number target and index1 < index2. Note that index1 and index2 cannot be equal, therefore you may not use the same element twice.

There will always be exactly one valid solution.

Your solution must use 
O(1) additional space.

Example 1:

Input: numbers = [1,2,3,4], target = 3

Output: [1,2]
"""

class Solution:
    def twoSum(self, numbers: List[int], target: int) -> List[int]:
        # Start one pointer at the beginning
        left = 0

        # Start one pointer at the end
        right = len(numbers) - 1

        # Keep checking while the two pointers have not crossed
        while left < right:
            # Add the two numbers at the current pointers
            total = numbers[left] + numbers[right]

            # If the sum equals the target, return the 1-indexed positions
            if total == target:
                return [left + 1, right + 1]

            # If the sum is too small, move left pointer forward
            # This gives us a bigger number because the array is sorted
            elif total < target:
                left += 1

            # If the sum is too large, move right pointer backward
            # This gives us a smaller number because the array is sorted
            else:
                right -= 1
